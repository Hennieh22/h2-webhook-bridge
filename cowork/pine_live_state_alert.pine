// ── Live State Alert ──────────────────────────────────────────────────────────
// Fires on every confirmed bar close. Sends current 1H/4H/Daily VWAP
// destinations + journey state to the Railway bridge so the Python
// scan system can read live directional targets instead of ATR estimates.
//
// Confirmed variable names from H2_MTF_v1.pine:
//   dest_1, dir_1, regime_1   — 1H VWAP destination, direction (BULL/BEAR), regime
//   dest_4, dir_4, regime_4   — 4H
//   dest_d, dir_d, regime_d   — Daily
//   journey_state             — integer 1-5
//
// dir_1/dir_4/dir_d are "BULL"/"BEAR" in Pine; converted to "UP"/"DOWN" for
// the scan system (h2_scan.py expects "UP"/"DOWN" for destination flip logic).
//
// NOTE: Uses alert() not alertcondition().
// alertcondition() requires a compile-time constant string — our JSON is
// dynamically built at runtime, so alert() is required instead.
// In TradingView: Alerts panel → Create Alert → Condition: H2 MTF v1.0
// (the alert fires automatically on every bar close via the script itself).
//
// Webhook URL for all instruments:
//   https://h2-webhook-bridge-production-872e.up.railway.app/live_state
//
// How to activate:
//   1. Insert this block above the final plot(na) in H2_MTF_v1.pine
//      (or use the complete pine/H2_MTF_v1.pine which already includes it)
//   2. Save the script and add to chart
//   3. In TradingView Alerts panel, create an alert:
//        Condition  → H2 MTF v1.0 (the script itself)
//        Webhook URL → https://h2-webhook-bridge-production-872e.up.railway.app/live_state
//        Message    → (leave as {{strategy.order.alert_message}} or any placeholder —
//                      the alert() call in the script overrides the message)
//   4. Repeat for each instrument (JP225, USTEC, XAUUSD, DE40, UK100, USDJPY, XAGUSD)

live_state_json = '{"type":"live_state"' +
     ',"symbol":"'       + syminfo.ticker + '"' +
     ',"dest_1h":'       + str.tostring(dest_1, "#.##") +
     ',"dir_1h":"'       + (dir_1 == "BULL" ? "UP" : "DOWN") + '"' +
     ',"dest_4h":'       + str.tostring(dest_4, "#.##") +
     ',"dir_4h":"'       + (dir_4 == "BULL" ? "UP" : "DOWN") + '"' +
     ',"dest_d":'        + str.tostring(dest_d, "#.##") +
     ',"dir_d":"'        + (dir_d == "BULL" ? "UP" : "DOWN") + '"' +
     ',"regime":"'       + regime_4 + '"' +
     ',"journey_state":' + str.tostring(journey_state) +
     ',"timestamp":'     + str.tostring(math.round(time / 1000)) +
     '}'

if barstate.isconfirmed
    alert(live_state_json, alert.freq_once_per_bar_close)
