// H2 State Overlay v2.0
// H2 Systematic Trading
// © 2026 H2 Quant Systems
// Invite-only — do not redistribute
//
// Live data overlay for H2 Quant state engine.
// Data pulled automatically via request.json() from Railway endpoint.
// Select instrument in Settings → Data Source → Instrument.
// No manual input needed. Updates every bar from live JSON.
//
// v2.0 — switched from manual inputs to request.json() live data feed
//         endpoint: /api/live-state/{instrument}

//@version=5
indicator("H2 State Overlay v2.0", overlay=true, max_boxes_count=10, max_lines_count=50, max_labels_count=500, shorttitle="H2")

// ═══════════════════════════════════════════════════════════════════════════
// GROUP 1 — LAYOUT & APPEARANCE
// ═══════════════════════════════════════════════════════════════════════════

var G_LAYOUT = "Layout and Appearance"

i_left_pos    = input.string("Top Left",  "Left Panel Position",  options=["Top Left","Top Center","Top Right","Middle Left","Middle Center","Middle Right","Bottom Left","Bottom Center","Bottom Right"], group=G_LAYOUT)
i_right_pos   = input.string("Top Right", "Right Panel Position", options=["Top Left","Top Center","Top Right","Middle Left","Middle Center","Middle Right","Bottom Left","Bottom Center","Bottom Right"], group=G_LAYOUT)
i_text_header = input.string("Normal", "Header Text Size", options=["Tiny","Small","Normal","Large","Huge"], group=G_LAYOUT)
i_text_body   = input.string("Small",  "Body Text Size",   options=["Tiny","Small","Normal","Large","Huge"], group=G_LAYOUT)
i_text_stats  = input.string("Tiny",   "Stats Text Size",  options=["Tiny","Small","Normal","Large","Huge"], group=G_LAYOUT)
i_theme       = input.string("Black",  "Theme",            options=["Black","Dark","Midnight","Charcoal"],   group=G_LAYOUT)
i_opacity     = input.int(10, "Panel Transparency Pct", minval=0, maxval=90, step=5, group=G_LAYOUT)
i_show_left    = input.bool(true, "Show State Panel",      group=G_LAYOUT)
i_show_right   = input.bool(true, "Show Gate Panel",       group=G_LAYOUT)
i_show_dwell   = input.bool(true, "Show Dwell Label",      group=G_LAYOUT)
i_show_bg_tint = input.bool(true, "Show Background Tint",  group=G_LAYOUT)

// ═══════════════════════════════════════════════════════════════════════════
// GROUP 2 — DATA SOURCE
// ═══════════════════════════════════════════════════════════════════════════
// Paste your ngrok URL here. Data is fetched automatically every bar refresh.
// How to get the URL:
//   1. Run start_h2.bat on your Windows machine
//   2. Copy the ngrok URL printed in the monitor startup banner
//   3. Paste it in the field below (no trailing slash)
// Example: https://abc123.ngrok-free.app
//
// If the URL is empty or ngrok is not running, all fields show "LOADING..."
// No other manual input needed — all data comes from the live JSON endpoint.

var G_SOURCE = "Data Source"

i_instrument = input.string("US30", "Instrument",
     options=["US30","GBPUSD","DE40","XAUUSD","GBPJPY","EURJPY"],
     tooltip="Select the H2 Quant instrument to display. Changing this re-fetches live data automatically.",
     group=G_SOURCE)

i_ngrok_url = input.string(
     "",
     "Dashboard URL (ngrok)",
     tooltip="Paste your ngrok public URL here. Example: https://abc123.ngrok-free.app  |  Get it from the monitor startup banner or run: ngrok http 5050",
     group=G_SOURCE)

// ═══════════════════════════════════════════════════════════════════════════
// LIVE DATA — request.json()
// ═══════════════════════════════════════════════════════════════════════════
// All fields fetched from /api/live-state/{instrument} using JSON Pointers.
// Multiple calls with the same URL share a single HTTP request (Pine caches).
// 26 request.json() calls — within the 40-call limit.
//
// If i_ngrok_url is empty we point at a harmless placeholder so request.json()
// returns na for every field — the na() fallbacks show "LOADING..." cleanly.
// No error is thrown because ignore_invalid_symbols=true.

_url_base = str.length(i_ngrok_url) > 8 ? i_ngrok_url : "https://example.com/h2/na"
url = _url_base + "/api/live-state/" + i_instrument

// ── Current state ────────────────────────────────────────────────────────
_r_state  = request.json(url, "/current_state",    ignore_invalid_symbols=true)
_r_desc   = request.json(url, "/state_description", ignore_invalid_symbols=true)
_r_sess   = request.json(url, "/session",           ignore_invalid_symbols=true)
_r_sast   = request.json(url, "/generated_at_sast", ignore_invalid_symbols=true)
_r_dwell_c = request.json(url, "/dwell_time_current_bars", ignore_invalid_symbols=true)
_r_dwell_a = request.json(url, "/dwell_time_avg_bars",     ignore_invalid_symbols=true)

i_state       = na(_r_state)   ? "LOADING..."          : str.tostring(_r_state)
i_description = na(_r_desc)    ? "Waiting for data..."  : str.tostring(_r_desc)
i_session     = na(_r_sess)    ? "OFFHOURS"             : str.tostring(_r_sess)
i_dwell_bars  = na(_r_dwell_c) ? 0 : math.round(float(_r_dwell_c))
i_dwell_avg   = na(_r_dwell_a) ? 0.0 : float(_r_dwell_a)

// Extract HH:MM from "2026-06-09T10:32:55+02:00"
_sast_str   = na(_r_sast) ? "--:--" : str.tostring(_r_sast)
i_sast_time = str.length(_sast_str) >= 16 ? str.substring(_sast_str, 11, 16) : _sast_str

// ── Next states ──────────────────────────────────────────────────────────
_r_next1  = request.json(url, "/next_states/0/state",       ignore_invalid_symbols=true)
_r_prob1  = request.json(url, "/next_states/0/probability", ignore_invalid_symbols=true)
_r_ev1    = request.json(url, "/next_states/0/ev",          ignore_invalid_symbols=true)

_r_next2  = request.json(url, "/next_states/1/state",       ignore_invalid_symbols=true)
_r_prob2  = request.json(url, "/next_states/1/probability", ignore_invalid_symbols=true)
_r_ev2    = request.json(url, "/next_states/1/ev",          ignore_invalid_symbols=true)

_r_next3  = request.json(url, "/next_states/2/state",       ignore_invalid_symbols=true)
_r_prob3  = request.json(url, "/next_states/2/probability", ignore_invalid_symbols=true)
_r_ev3    = request.json(url, "/next_states/2/ev",          ignore_invalid_symbols=true)

i_next1 = na(_r_next1) ? "—" : str.tostring(_r_next1)
i_prob1 = na(_r_prob1) ? 0.0 : float(_r_prob1)
i_ev1   = na(_r_ev1)   ? 0.0 : float(_r_ev1)

i_next2 = na(_r_next2) ? "—" : str.tostring(_r_next2)
i_prob2 = na(_r_prob2) ? 0.0 : float(_r_prob2)
i_ev2   = na(_r_ev2)   ? 0.0 : float(_r_ev2)

i_next3 = na(_r_next3) ? "—" : str.tostring(_r_next3)
i_prob3 = na(_r_prob3) ? 0.0 : float(_r_prob3)
i_ev3   = na(_r_ev3)   ? 0.0 : float(_r_ev3)

// ── Gate values ──────────────────────────────────────────────────────────
_r_gap  = request.json(url, "/gates/markov_gap/value",         ignore_invalid_symbols=true)
_r_pers = request.json(url, "/gates/markov_persistence/value", ignore_invalid_symbols=true)
_r_vol  = request.json(url, "/gates/volatility_cap/value",     ignore_invalid_symbols=true)
_r_hrst = request.json(url, "/gates/hurst/value",              ignore_invalid_symbols=true)
_r_sess_gate = request.json(url, "/gates/session/pass",        ignore_invalid_symbols=true)

i_g_markov_gap  = na(_r_gap)       ? 0.0   : float(_r_gap)
i_g_persistence = na(_r_pers)      ? 0.0   : float(_r_pers)
i_g_vol_cap     = na(_r_vol)       ? 1.0   : float(_r_vol)
i_g_hurst       = na(_r_hrst)      ? 0.5   : float(_r_hrst)
i_g_session_ok  = na(_r_sess_gate) ? false : bool(_r_sess_gate)

// ── Conviction & stats ───────────────────────────────────────────────────
_r_conv    = request.json(url, "/conviction",        ignore_invalid_symbols=true)
_r_pillars = request.json(url, "/pillars_confirmed", ignore_invalid_symbols=true)
_r_wr      = request.json(url, "/historical_wr",     ignore_invalid_symbols=true)
_r_ev_hist = request.json(url, "/historical_ev",     ignore_invalid_symbols=true)
_r_samp    = request.json(url, "/sample_count",      ignore_invalid_symbols=true)

i_conviction = na(_r_conv)    ? "SKIP" : str.tostring(_r_conv)
i_pillars    = na(_r_pillars) ? 0      : math.round(float(_r_pillars))
i_hist_wr    = na(_r_wr)      ? 0.0    : float(_r_wr)
i_hist_ev    = na(_r_ev_hist) ? 0.0    : float(_r_ev_hist)
i_samples    = na(_r_samp)    ? 0      : math.round(float(_r_samp))

// ═══════════════════════════════════════════════════════════════════════════
// MAPPERS
// ═══════════════════════════════════════════════════════════════════════════

pos_from_string(pos_str) =>
    switch pos_str
        "Top Left"      => position.top_left
        "Top Center"    => position.top_center
        "Top Right"     => position.top_right
        "Middle Left"   => position.middle_left
        "Middle Center" => position.middle_center
        "Middle Right"  => position.middle_right
        "Bottom Left"   => position.bottom_left
        "Bottom Center" => position.bottom_center
        "Bottom Right"  => position.bottom_right
        =>                 position.top_left

size_from_string(sz) =>
    switch sz
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge
        =>          size.small

// ═══════════════════════════════════════════════════════════════════════════
// THEME COLORS
// ═══════════════════════════════════════════════════════════════════════════

bg_hex   = i_theme == "Black" ? #000000 : i_theme == "Dark" ? #0d1117 : i_theme == "Midnight" ? #010409 : #1a1a2e
mid_hex  = i_theme == "Black" ? #0a0a0a : i_theme == "Dark" ? #161b22 : i_theme == "Midnight" ? #0d1117 : #16213e
cell_hex = i_theme == "Black" ? #111111 : i_theme == "Dark" ? #1c2128 : i_theme == "Midnight" ? #161b22 : #0f3460

C_BG   = color.new(bg_hex,   i_opacity)
C_MID  = color.new(mid_hex,  i_opacity)
C_CELL = color.new(cell_hex, i_opacity)
C_HDR  = color.new(bg_hex,   math.max(0, i_opacity - 5))

C_GREEN  = #26a69a
C_RED    = #ef5350
C_ORANGE = #ff9800
C_GRAY   = #787b86
C_PURPLE = #7c4dff
C_GOLD   = #ffd700
C_WHITE  = #ffffff

frame_hex = i_theme == "Charcoal" ? #533483 : #7c4dff
C_FRAME   = color.new(frame_hex, 20)
C_BORDER  = color.new(#444444, 60)

// ═══════════════════════════════════════════════════════════════════════════
// DERIVED VALUES
// ═══════════════════════════════════════════════════════════════════════════

gate1_pass = i_g_markov_gap  >= 0.61
gate2_pass = i_g_persistence >= 0.82
gate3_pass = i_g_vol_cap     <= 1.25
gate4_pass = i_g_hurst       >= 0.50
gate5_pass = i_g_session_ok
all_gates  = gate1_pass and gate2_pass and gate3_pass and gate4_pass and gate5_pass

conv_color = i_conviction == "A+" ? C_GOLD : i_conviction == "A" ? C_GREEN : i_conviction == "B" ? C_ORANGE : C_RED

dwell_pct   = i_dwell_avg > 0 ? i_dwell_bars / i_dwell_avg : 0.0
dwell_color = dwell_pct >= 0.9 ? C_ORANGE : dwell_pct >= 0.6 ? color.new(C_ORANGE, 60) : C_GRAY

state_parts = str.split(i_state, "_")
trend_lbl   = array.size(state_parts) > 0 ? array.get(state_parts, 0) : "?"
trend_color = trend_lbl == "BULL" ? C_GREEN : trend_lbl == "BEAR" ? C_RED : C_GRAY

prob_color(p) => p >= 0.60 ? C_GREEN : p >= 0.40 ? C_ORANGE : C_GRAY
ev_color(e)   => e > 0.3 ? C_GREEN : e < 0.0 ? C_RED : C_ORANGE
gate_icon(g)  => g ? "OK" : "XX"
gate_col(g)   => g ? C_GREEN : C_RED
gate_bg(g)    => g ? color.new(C_GREEN, 70) : color.new(C_RED, 70)

sz_h = size_from_string(i_text_header)
sz_b = size_from_string(i_text_body)
sz_s = size_from_string(i_text_stats)

// ═══════════════════════════════════════════════════════════════════════════
// LEFT TABLE — State panel
// ═══════════════════════════════════════════════════════════════════════════

var table  tbl_left      = na
var string prev_left_pos = ""

if barstate.islast
    if not i_show_left
        if not na(tbl_left)
            table.delete(tbl_left)
            tbl_left      := na
            prev_left_pos := ""
    else
        if i_left_pos != prev_left_pos or na(tbl_left)
            if not na(tbl_left)
                table.delete(tbl_left)
            tbl_left      := table.new(pos_from_string(i_left_pos), 3, 9, bgcolor=C_BG, border_color=C_BORDER, border_width=1, frame_color=C_FRAME, frame_width=2)
            prev_left_pos := i_left_pos

        // Row 0: Header — shows instrument name + session + SAST time
        //         Appends "(no URL)" warning if ngrok URL not set
        _url_ok     = str.length(i_ngrok_url) > 8
        _url_suffix = _url_ok ? (i_session + "  " + i_sast_time + " SAST") : "PASTE NGROK URL"
        inst_header = i_instrument + "  |  " + _url_suffix
        table.cell(tbl_left, 0, 0, "H2 QUANT",    text_color=C_GOLD,  text_size=sz_h, bgcolor=C_HDR, text_halign=text.align_left)
        table.cell(tbl_left, 1, 0, "LIVE STATE",   text_color=C_GOLD,  text_size=sz_h, bgcolor=C_HDR)
        table.merge_cells(tbl_left, 0, 0, 1, 0)
        table.cell(tbl_left, 2, 0, inst_header,    text_color=C_GRAY,  text_size=sz_s, bgcolor=C_HDR, text_halign=text.align_right)

        // Row 1: State ID
        table.cell(tbl_left, 0, 1, "STATE",   text_color=C_GRAY,       text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_left, 1, 1, i_state,   text_color=trend_color,  text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_left)
        table.merge_cells(tbl_left, 1, 1, 2, 1)

        // Row 2: Description
        table.cell(tbl_left, 0, 2, "DESC",         text_color=C_GRAY,  text_size=sz_s, bgcolor=C_MID, text_halign=text.align_left)
        table.cell(tbl_left, 1, 2, i_description,  text_color=C_WHITE, text_size=sz_s, bgcolor=C_MID, text_halign=text.align_left)
        table.merge_cells(tbl_left, 1, 2, 2, 2)

        // Row 3: Dwell
        dwell_str = "Bar " + str.tostring(i_dwell_bars) + " / avg " + str.tostring(math.round(i_dwell_avg, 1))
        table.cell(tbl_left, 0, 3, "DWELL",    text_color=C_GRAY,        text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_left, 1, 3, dwell_str,  text_color=dwell_color,   text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_left)
        table.merge_cells(tbl_left, 1, 3, 2, 3)

        // Row 4: Next states header
        table.cell(tbl_left, 0, 4, "NEXT STATES", text_color=C_PURPLE, text_size=sz_b, bgcolor=color.new(C_PURPLE, 85), text_halign=text.align_left)
        table.cell(tbl_left, 1, 4, "PROB",        text_color=C_GRAY,   text_size=sz_b, bgcolor=color.new(C_PURPLE, 85), text_halign=text.align_center)
        table.cell(tbl_left, 2, 4, "EV",          text_color=C_GRAY,   text_size=sz_b, bgcolor=color.new(C_PURPLE, 85), text_halign=text.align_center)

        // Row 5: Next state 1
        prob1_str = str.tostring(math.round(i_prob1 * 100, 1)) + "%"
        ev1_str   = (i_ev1 >= 0 ? "+" : "-") + str.tostring(math.round(math.abs(i_ev1), 2)) + "R"
        table.cell(tbl_left, 0, 5, i_next1,    text_color=prob_color(i_prob1), text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_left, 1, 5, prob1_str,  text_color=prob_color(i_prob1), text_size=sz_b, bgcolor=color.new(prob_color(i_prob1), 80), text_halign=text.align_center)
        table.cell(tbl_left, 2, 5, ev1_str,    text_color=ev_color(i_ev1),     text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)

        // Row 6: Next state 2
        prob2_str = str.tostring(math.round(i_prob2 * 100, 1)) + "%"
        ev2_str   = (i_ev2 >= 0 ? "+" : "-") + str.tostring(math.round(math.abs(i_ev2), 2)) + "R"
        table.cell(tbl_left, 0, 6, i_next2,    text_color=prob_color(i_prob2), text_size=sz_s, bgcolor=C_MID, text_halign=text.align_left)
        table.cell(tbl_left, 1, 6, prob2_str,  text_color=prob_color(i_prob2), text_size=sz_b, bgcolor=color.new(prob_color(i_prob2), 85), text_halign=text.align_center)
        table.cell(tbl_left, 2, 6, ev2_str,    text_color=ev_color(i_ev2),     text_size=sz_b, bgcolor=C_MID, text_halign=text.align_center)

        // Row 7: Next state 3
        prob3_str = str.tostring(math.round(i_prob3 * 100, 1)) + "%"
        ev3_str   = (i_ev3 >= 0 ? "+" : "-") + str.tostring(math.round(math.abs(i_ev3), 2)) + "R"
        table.cell(tbl_left, 0, 7, i_next3,    text_color=prob_color(i_prob3), text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_left, 1, 7, prob3_str,  text_color=prob_color(i_prob3), text_size=sz_b, bgcolor=color.new(prob_color(i_prob3), 85), text_halign=text.align_center)
        table.cell(tbl_left, 2, 7, ev3_str,    text_color=ev_color(i_ev3),     text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)

// ═══════════════════════════════════════════════════════════════════════════
// RIGHT TABLE — Gate + Conviction panel
// ═══════════════════════════════════════════════════════════════════════════

var table  tbl_right      = na
var string prev_right_pos = ""

if barstate.islast
    if not i_show_right
        if not na(tbl_right)
            table.delete(tbl_right)
            tbl_right      := na
            prev_right_pos := ""
    else
        if i_right_pos != prev_right_pos or na(tbl_right)
            if not na(tbl_right)
                table.delete(tbl_right)
            tbl_right      := table.new(pos_from_string(i_right_pos), 4, 12, bgcolor=C_BG, border_color=C_BORDER, border_width=1, frame_color=C_FRAME, frame_width=2)
            prev_right_pos := i_right_pos

        // Row 0: Gate header
        table.cell(tbl_right, 0, 0, "GATE",   text_color=C_GOLD, text_size=sz_h, bgcolor=C_HDR, text_halign=text.align_left)
        table.cell(tbl_right, 1, 0, "STATUS", text_color=C_GOLD, text_size=sz_h, bgcolor=C_HDR, text_halign=text.align_center)
        table.cell(tbl_right, 2, 0, "VALUE",  text_color=C_GOLD, text_size=sz_h, bgcolor=C_HDR, text_halign=text.align_center)
        table.cell(tbl_right, 3, 0, "NEED",   text_color=C_GOLD, text_size=sz_h, bgcolor=C_HDR, text_halign=text.align_center)

        // Row 1: Markov Gap
        gap_val_str = str.tostring(math.round(i_g_markov_gap * 100, 1)) + "%"
        table.cell(tbl_right, 0, 1, "Markov Gap",          text_color=C_WHITE,              text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_right, 1, 1, gate_icon(gate1_pass), text_color=gate_col(gate1_pass), text_size=sz_h, bgcolor=gate_bg(gate1_pass), text_halign=text.align_center)
        table.cell(tbl_right, 2, 1, gap_val_str,           text_color=gate_col(gate1_pass), text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 3, 1, ">=61%",               text_color=C_GRAY,               text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)

        // Row 2: Persistence
        pers_val_str = str.tostring(math.round(i_g_persistence * 100, 1)) + "%"
        table.cell(tbl_right, 0, 2, "Persistence",         text_color=C_WHITE,              text_size=sz_b, bgcolor=C_MID, text_halign=text.align_left)
        table.cell(tbl_right, 1, 2, gate_icon(gate2_pass), text_color=gate_col(gate2_pass), text_size=sz_h, bgcolor=gate_bg(gate2_pass), text_halign=text.align_center)
        table.cell(tbl_right, 2, 2, pers_val_str,          text_color=gate_col(gate2_pass), text_size=sz_b, bgcolor=C_MID, text_halign=text.align_center)
        table.cell(tbl_right, 3, 2, ">=82%",               text_color=C_GRAY,               text_size=sz_s, bgcolor=C_MID, text_halign=text.align_center)

        // Row 3: Vol Cap
        vol_val_str = str.tostring(math.round(i_g_vol_cap, 2)) + "x"
        table.cell(tbl_right, 0, 3, "Vol Cap",             text_color=C_WHITE,              text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_right, 1, 3, gate_icon(gate3_pass), text_color=gate_col(gate3_pass), text_size=sz_h, bgcolor=gate_bg(gate3_pass), text_halign=text.align_center)
        table.cell(tbl_right, 2, 3, vol_val_str,           text_color=gate_col(gate3_pass), text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 3, 3, "<=1.25x",             text_color=C_GRAY,               text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)

        // Row 4: Hurst
        hurst_val_str = str.tostring(math.round(i_g_hurst, 2))
        table.cell(tbl_right, 0, 4, "Hurst",               text_color=C_WHITE,              text_size=sz_b, bgcolor=C_MID, text_halign=text.align_left)
        table.cell(tbl_right, 1, 4, gate_icon(gate4_pass), text_color=gate_col(gate4_pass), text_size=sz_h, bgcolor=gate_bg(gate4_pass), text_halign=text.align_center)
        table.cell(tbl_right, 2, 4, hurst_val_str,         text_color=gate_col(gate4_pass), text_size=sz_b, bgcolor=C_MID, text_halign=text.align_center)
        table.cell(tbl_right, 3, 4, ">=0.50",              text_color=C_GRAY,               text_size=sz_s, bgcolor=C_MID, text_halign=text.align_center)

        // Row 5: Session
        sess_need_str = gate5_pass ? "OK" : "WAIT"
        table.cell(tbl_right, 0, 5, "Session",             text_color=C_WHITE,              text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_left)
        table.cell(tbl_right, 1, 5, gate_icon(gate5_pass), text_color=gate_col(gate5_pass), text_size=sz_h, bgcolor=gate_bg(gate5_pass), text_halign=text.align_center)
        table.cell(tbl_right, 2, 5, i_session,             text_color=gate_col(gate5_pass), text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 3, 5, sess_need_str,         text_color=gate_col(gate5_pass), text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)

        // Row 6: All gates banner
        gates_txt = all_gates ? "ALL GATES PASS" : "GATES FAILING"
        gates_tc  = all_gates ? C_GREEN : C_RED
        gates_bg  = all_gates ? color.new(C_GREEN, 50) : color.new(C_RED, 50)
        table.cell(tbl_right, 0, 6, gates_txt, text_color=gates_tc, text_size=sz_b, bgcolor=gates_bg, text_halign=text.align_center)
        table.merge_cells(tbl_right, 0, 6, 3, 6)

        // Row 7: Conviction header
        table.cell(tbl_right, 0, 7, "CONVICTION", text_color=C_GOLD, text_size=sz_b, bgcolor=C_HDR, text_halign=text.align_center)
        table.merge_cells(tbl_right, 0, 7, 3, 7)

        // Row 8: Conviction rating
        table.cell(tbl_right, 0, 8, i_conviction, text_color=conv_color, text_size=size.large, bgcolor=color.new(conv_color, 65), text_halign=text.align_center)
        table.merge_cells(tbl_right, 0, 8, 3, 8)

        // Row 9: Pillar diamonds
        p1 = i_pillars >= 1 ? "+" : "o"
        p2 = i_pillars >= 2 ? "+" : "o"
        p3 = i_pillars >= 3 ? "+" : "o"
        p4 = i_pillars >= 4 ? "+" : "o"
        pil_str = p1 + " " + p2 + " " + p3 + " " + p4 + "  " + str.tostring(i_pillars) + "/4 pillars"
        table.cell(tbl_right, 0, 9, pil_str, text_color=conv_color, text_size=sz_b, bgcolor=color.new(conv_color, 85), text_halign=text.align_center)
        table.merge_cells(tbl_right, 0, 9, 3, 9)

        // Row 10: Stats labels
        table.cell(tbl_right, 0, 10, "WR",      text_color=C_GRAY, text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 1, 10, "EV",      text_color=C_GRAY, text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 2, 10, "Samples", text_color=C_GRAY, text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 3, 10, "Stab",    text_color=C_GRAY, text_size=sz_s, bgcolor=C_CELL, text_halign=text.align_center)

        // Row 11: Stats values
        wr_col   = i_hist_wr >= 0.60 ? C_GREEN : i_hist_wr >= 0.50 ? C_ORANGE : C_RED
        ev_col2  = i_hist_ev > 0.3   ? C_GREEN : i_hist_ev < 0.0   ? C_RED    : C_ORANGE
        samp_col = i_samples >= 30   ? C_WHITE : C_RED
        wr_str   = str.tostring(math.round(i_hist_wr * 100, 1)) + "%"
        ev_str   = (i_hist_ev >= 0 ? "+" : "") + str.tostring(math.round(i_hist_ev, 2)) + "R"
        samp_str = str.tostring(i_samples)
        table.cell(tbl_right, 0, 11, wr_str,   text_color=wr_col,   text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 1, 11, ev_str,   text_color=ev_col2,  text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 2, 11, samp_str, text_color=samp_col, text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)
        table.cell(tbl_right, 3, 11, "-",      text_color=C_GRAY,   text_size=sz_b, bgcolor=C_CELL, text_halign=text.align_center)

// ═══════════════════════════════════════════════════════════════════════════
// DWELL COUNTER LABEL
// ═══════════════════════════════════════════════════════════════════════════

var label lbl_dwell = na
label.delete(lbl_dwell[1])

if i_show_dwell and barstate.islast
    dwell_lbl_str = "In state: " + str.tostring(i_dwell_bars) + " bars (avg " + str.tostring(math.round(i_dwell_avg, 1)) + ")"
    lbl_dwell := label.new(bar_index, high, dwell_lbl_str, style=label.style_label_lower_right, color=color.new(dwell_color, 70), textcolor=C_WHITE, size=sz_s)

// ═══════════════════════════════════════════════════════════════════════════
// STATE CHANGE MARKER
// ═══════════════════════════════════════════════════════════════════════════

conv_num      = i_conviction == "A+" ? 4 : i_conviction == "A" ? 3 : i_conviction == "B" ? 2 : 1
state_changed = ta.change(conv_num) != 0 or ta.change(i_pillars) != 0

if state_changed and not barstate.isfirst
    abbr_parts  = str.split(i_state, "_")
    abbr_trend  = array.size(abbr_parts) > 0 ? array.get(abbr_parts, 0) : "?"
    abbr_struct = array.size(abbr_parts) > 5 ? array.get(abbr_parts, 5) : "?"
    abbr_str    = abbr_trend + "/" + abbr_struct
    label.new(bar_index, high * 1.001, abbr_str, style=label.style_label_down, color=color.new(conv_color, 40), textcolor=C_WHITE, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// BACKGROUND TINT
// ═══════════════════════════════════════════════════════════════════════════

bg_tint_base  = i_conviction == "A+" ? color.new(C_GOLD, 97) : i_conviction == "A" ? color.new(C_GREEN, 97) : i_conviction == "B" ? color.new(C_ORANGE, 97) : color.new(C_RED, 99)
bg_tint_final = (i_show_bg_tint and all_gates) ? bg_tint_base : color.new(color.black, 100)
bgcolor(bg_tint_final, title="Conviction background tint")

plot(na, title="H2 State Overlay - display only")
