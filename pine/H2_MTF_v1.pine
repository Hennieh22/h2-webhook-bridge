//@version=6
indicator("H2 MTF Journey v1.0", shorttitle="H2·MTF", overlay=true, max_labels_count=10, max_lines_count=10)

// ── INPUTS ───────────────────────────────────────────────────────────────────
grp_tf = "Timeframes"
tf_weekly  = input.timeframe("W",   "Weekly TF",  group=grp_tf)
tf_daily   = input.timeframe("D",   "Daily TF",   group=grp_tf)
tf_h4      = input.timeframe("240", "4H TF",      group=grp_tf)
tf_h1      = input.timeframe("60",  "1H TF",      group=grp_tf)
tf_m15     = input.timeframe("15",  "15M TF",     group=grp_tf)

grp_display = "Display"
tbl_size_in = input.string("Normal", "Table Size", options=["Tiny","Small","Normal","Large"], group=grp_display)
show_weekly = input.bool(true, "Show Weekly Row", group=grp_display)

grp_lines = "Destination Lines"
show_lines     = input.bool(true,           "Show Destination Lines", group=grp_lines)
line_daily_col = input.color(color.yellow,  "Daily Line Color",       group=grp_lines)
line_h4_col    = input.color(color.orange,  "4H Line Color",          group=grp_lines)
line_h1_col    = input.color(color.aqua,    "1H Line Color",          group=grp_lines)
line_m15_col   = input.color(color.white,   "15M Line Color",         group=grp_lines)
line_width     = input.int(1, "Line Width", minval=1, maxval=4,        group=grp_lines)
line_style_inp = input.string("Dashed", "Line Style", options=["Solid","Dashed","Dotted"], group=grp_lines)
label_offset   = input.int(8, "Label Bar Offset (bars right)", minval=1, maxval=20, group=grp_lines)
label_size_inp = input.string("Small", "Label Size", options=["Tiny","Small","Normal","Large"], group=grp_lines)

// ── TIME-DISTANCE PRESSURE ────────────────────────────────────────────────────
// Default OFF — existing table is visually identical when disabled.
grp_td       = "Time-Distance Pressure"
show_td      = input.bool(false, "Show Time-Distance States", group=grp_td)
td_lookback  = input.int(8, "Lookback (bars)", minval=2, maxval=20, group=grp_td)
td_slope_thr = input.float(0.10, "Slope Threshold (ATR multiples)", minval=0.01, maxval=0.5, step=0.01, group=grp_td)

// ── PROP FIRM GATE ────────────────────────────────────────────────────────────
// Default OFF — table identical when disabled.
grp_prop       = "Prop Firm Gate"
show_prop      = input.bool(false, "Show Prop Firm Gate",            group=grp_prop)
prop_acct_size = input.float(50000, "Account Size ($)",              group=grp_prop, step=1000)
prop_daily_dd  = input.float(5.0,  "Daily Drawdown Limit (%)",      group=grp_prop, step=0.5)
prop_max_dd    = input.float(10.0, "Max Total Drawdown (%)",         group=grp_prop, step=0.5)
prop_risk_pct  = input.float(0.5,  "Risk Per Trade (%)",             group=grp_prop, step=0.1)
prop_max_pos   = input.int(5,      "Max Concurrent Positions",       group=grp_prop)
prop_max_tr    = input.int(5,      "Max Trades Per Day",             group=grp_prop)
prop_min_audit = input.int(8,      "Min Audit Score (0-10)",         group=grp_prop)
prop_min_js    = input.int(3,      "Min Journey State (1=State1 only, 3=States 1+3)", group=grp_prop)
prop_min_td    = input.int(1,      "Min TD Combined Score (-3 to +3)", group=grp_prop)
prop_news_ok   = input.bool(true,  "News Trading Allowed",           group=grp_prop)
prop_wknd_ok   = input.bool(true,  "Weekend Holding Allowed",        group=grp_prop)
prop_ovn_ok    = input.bool(true,  "Overnight Holding Allowed",      group=grp_prop)
prop_dd_used   = input.float(0.0,  "Drawdown Used Today ($)",        group=grp_prop, step=10)
prop_pos_open  = input.int(0,      "Open Positions Right Now",       group=grp_prop)
prop_tr_today  = input.int(0,      "Trades Taken Today",             group=grp_prop)
prop_audit_cur = input.int(8,      "Current Audit Score (from Panel 1)", group=grp_prop)

// ── HELPERS ──────────────────────────────────────────────────────────────────
f_sz(s)     => s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : size.normal
f_lstyle(s) => s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed

// ── UNIFIED PER-TF STATE FUNCTION ────────────────────────────────────────────
// Called via request.security — evaluated entirely on the target timeframe.
// Sigma uses the same population-variance formula as the Audit panel:
//   σ² = E[P²] − E[P]²  where E is volume-weighted and resets at the UTC day open.
// Each request.security call site gets its own var state, so accumulators are
// independent across timeframes and correctly track the target TF's session.
f_full_state() =>
    bool  _nd = ta.change(time("D")) != 0
    var float _cv   = 0.0
    var float _ctv  = 0.0
    var float _ct2v = 0.0
    if _nd
        _cv   := 0.0
        _ctv  := 0.0
        _ct2v := 0.0
    _cv   += volume
    _ctv  += hlc3 * volume
    _ct2v += hlc3 * hlc3 * volume
    float _vwap  = _cv > 0.0 ? _ctv / _cv : hlc3
    float _var   = _cv > 0.0 ? math.max(_ct2v / _cv - _vwap * _vwap, 0.0) : 0.0
    float _sig   = math.sqrt(_var)
    float _ratio = _sig > 0.0 ? math.abs(close - _vwap) / _sig : 0.0
    bool  _within = _ratio < 2.0
    float _dest  = _within ? (close > _vwap ? _vwap + 2.0 * _sig : _vwap - 2.0 * _sig) : _vwap
    string _src  = _within ? "VWAP±2σ" : "VWAP"
    string _dir  = close > _vwap ? "BULL" : "BEAR"
    string _rgm  = _within ? "WITHIN" : "BEYOND"
    float  _atr  = ta.atr(14)
    float  _rwy  = _atr > 0.0 ? math.round(math.abs(_dest - close) / _atr, 1) : 0.0
    [_vwap, _sig, _dir, _rgm, _dest, _src, _rwy]

// ── TIME-DISTANCE STATE CLASSIFIER ───────────────────────────────────────────
// Returns one of: "CONVERGING" / "APPROACHING" / "DIVERGING" / "STALLED"
// Validated on 9 months JP225+USTEC 1H data, 8-bar lookback, all p<0.0001:
//   APPROACHING: ~47-50% hit rate (+8pp vs baseline)
//   CONVERGING:  ~42-44% hit rate (+3pp vs baseline)
//   DIVERGING:   ~26-28% hit rate (-16pp vs baseline)
//   STALLED:     ~29-31% hit rate (-13pp vs baseline)
f_td_state(dest_now, dest_prior, price_now, price_prior, atr, n, slope_thr) =>
    dest_slope     = atr > 0 ? (dest_now - dest_prior) / n / atr : 0.0
    dist_now_val   = math.abs(price_now  - dest_now)
    dist_prior_val = math.abs(price_prior - dest_prior)
    dist_change    = dist_now_val - dist_prior_val
    dest_moving    = math.abs(dest_slope) >= slope_thr
    dist_shrinking = dist_change < -0.1 * atr
    if dest_moving and dist_shrinking
        "CONVERGING"
    else if dest_moving and not dist_shrinking
        "DIVERGING"
    else if not dest_moving and dist_shrinking
        "APPROACHING"
    else
        "STALLED"

f_td_col(state) =>
    if state == "CONVERGING"
        color.lime
    else if state == "APPROACHING"
        color.aqua
    else if state == "DIVERGING"
        color.red
    else
        color.gray

f_td_edge(state) =>
    if state == "APPROACHING"
        "+8pp"
    else if state == "CONVERGING"
        "+3pp"
    else if state == "DIVERGING"
        "-16pp"
    else
        "-13pp"

// ── VWAP FIELD DOMINANCE ─────────────────────────────────────────────────────
// gravity = inverse-distance + inverse-slope; higher = stronger active attractor
f_gravity(vwap_now, vwap_prior, price, atr, n) =>
    dist_norm  = atr > 0 ? math.abs(price - vwap_now) / atr : 999.0
    slope_norm = atr > 0 ? math.abs(vwap_now - vwap_prior) / n / atr : 999.0
    dist_score  = dist_norm  > 0 ? 1.0 / dist_norm  : 10.0
    slope_score = slope_norm > 0 ? 1.0 / slope_norm : 10.0
    math.min(dist_score, 10.0) + math.min(slope_score, 10.0)

// f_situation: journey + TD context sentence (~120 chars max per component)
f_situation(j_state, td_score, td_4h, dir4, dest4, runway4, weekly, dom, pressure) =>
    dir_word = dir4 == "BULL" ? "LONG" : "SHORT"
    opp_word = dir4 == "BULL" ? "upside" : "downside"
    dest_str = str.tostring(dest4, format.mintick)
    rwy_str  = str.tostring(runway4, "#.#")
    j_ctx = j_state == 1 ? dir_word + " destination " + dest_str + " (" + rwy_str + "R) in range. Highest-conviction entry window." : j_state == 2 ? "Pullback vs " + dir_word + " structure. System reloading — do not enter. Wait for 1H dest." : j_state == 3 ? "Pullback complete. " + opp_word + " resuming. Re-entry window open — often the cleanest entry of the move." : j_state == 4 ? "Beyond 4H VWAP bands. Overextended. Wait for LTF close back WITHIN regime." : "No delivery in progress. No momentum. Sit on hands."
    td_ctx = td_score >= 2 ? "All TFs CONVERGING — max mechanical tailwind." : td_score == 1 ? "Mostly positive TFs — moderate tailwind. Take the trade." : td_score == 0 ? "Mixed TF signals — balanced forces. Destination edge present, TD adds nothing." : td_score == -1 ? "One+ TFs DIVERGING — target retreating. Reduce size 50%. No pyramiding." : "Multiple TFs DIVERGING — strong headwind. Skip or minimum size only."
    td4h = td_4h == "DIVERGING" ? " WARN: 4H DIVERGING — target retreating on primary TF." : td_4h == "CONVERGING" ? " 4H CONVERGING — mechanical support on primary TF." : td_4h == "APPROACHING" ? " 4H APPROACHING — stable target, price closing in." : ""
    wk = weekly == "ALIGNED" ? "Weekly aligned — full size." : weekly == "OPPOSING" ? "Weekly opposing — full size (system rule)." : "Weekly neutral — 0.5x size."
    dom_ctx = dom == "DAILY" ? " Daily VWAP dominant attractor." : dom == "4H" ? " 4H VWAP controlling — not Daily." : " 1H micro-field pulling hardest."
    pres_ctx = pressure == "LOW" ? "" : pressure == "MEDIUM" ? " Displacement pressure building." : pressure == "HIGH" ? " High reversion fatigue — snap risk elevated." : " EXTREME pressure — expect sharp mean reversion."
    j_ctx + " " + td_ctx + td4h + dom_ctx + pres_ctx + " " + wk

// f_trigger: what specifically to watch for as the entry signal
f_trigger(j_state, dir4) =>
    dir_word = dir4 == "BULL" ? "LONG" : "SHORT"
    if j_state == 1
        "TRIGGER: Enter " + dir_word + " on next 15M bar that closes " + dir_word + " with RVOL declining on the approach bar."
    else if j_state == 2
        "TRIGGER: No " + dir_word + " entry yet. Watch 1H destination. When 1H prints a reversal candle and " + dir_word + " resumes, that is your entry."
    else if j_state == 3
        "TRIGGER: Enter " + dir_word + " immediately on 15M confirmation. Re-entry windows close fast."
    else if j_state == 4
        "TRIGGER: No " + dir_word + " entry yet. Wait for 4H to flip WITHIN. When STATE shifts to 1 or 3, enter " + dir_word + "."
    else
        "TRIGGER: No " + dir_word + " entry. Stand aside until new state develops."

// ── REQUEST PER TIMEFRAME ─────────────────────────────────────────────────────
[vwap_w, sigma_w, dir_w, regime_w, dest_w, src_w, runway_w] = request.security(syminfo.tickerid, tf_weekly, f_full_state(), lookahead=barmerge.lookahead_off)
[vwap_d, sigma_d, dir_d, regime_d, dest_d, src_d, runway_d] = request.security(syminfo.tickerid, tf_daily,  f_full_state(), lookahead=barmerge.lookahead_off)
[vwap_4, sigma_4, dir_4, regime_4, dest_4, src_4, runway_4] = request.security(syminfo.tickerid, tf_h4,     f_full_state(), lookahead=barmerge.lookahead_off)
[vwap_1, sigma_1, dir_1, regime_1, dest_1, src_1, runway_1] = request.security(syminfo.tickerid, tf_h1,     f_full_state(), lookahead=barmerge.lookahead_off)
[vwap_m, sigma_m, dir_m, regime_m, dest_m, src_m, runway_m] = request.security(syminfo.tickerid, tf_m15,    f_full_state(), lookahead=barmerge.lookahead_off)

// ── WEEKLY SIZE MODIFIER ─────────────────────────────────────────────────────
bool weekly_aligned  = dir_w == "BULL" and dir_4 == "BULL"
bool weekly_opposing = dir_w == "BEAR" and dir_4 == "BEAR"
string weekly_mod  = weekly_aligned ? "ALIGNED" : weekly_opposing ? "OPPOSING" : "NEUTRAL"
string weekly_size = weekly_aligned ? "Full size" : weekly_opposing ? "Full size" : "Reduced 0.5x"
color  weekly_col  = weekly_aligned ? color.lime : weekly_opposing ? color.red : color.yellow

// ── 4H JOURNEY STATE CLASSIFIER ─────────────────────────────────────────────
bool htf_agree   = dir_d == dir_4
bool ltf_confirm = dir_1 == dir_4
bool in_pullback = dir_1 != dir_4
bool near_dest   = runway_4 < 1.5

int journey_state = regime_4 == "WITHIN" and htf_agree and near_dest ? 1 : regime_4 == "WITHIN" and htf_agree and not near_dest and ltf_confirm ? 3 : regime_4 == "WITHIN" and not htf_agree ? 2 : regime_4 == "BEYOND" and regime_1 == "WITHIN" ? 4 : 5

string journey_label  = journey_state == 1 ? "STATE 1 — DESTINATION APPROACH" : journey_state == 2 ? "STATE 2 — PULLBACK IN PROGRESS" : journey_state == 3 ? "STATE 3 — RE-ENTRY OPPORTUNITY" : journey_state == 4 ? "STATE 4 — DISCOVERY CONSOLIDATION" : "STATE 5 — TRANSITION / NO TRADE"

color journey_col = journey_state == 1 ? color.lime : journey_state == 2 ? color.yellow : journey_state == 3 ? color.new(color.lime, 0) : journey_state == 4 ? color.orange : color.red

string journey_action = journey_state == 1 ? "Approaching destination — prepare entry" : journey_state == 2 ? "Pullback active — wait for " + tf_h1 + " dest: " + str.tostring(dest_1, format.mintick) : journey_state == 3 ? "Pullback complete — highest conviction entry" : journey_state == 4 ? "Discovery consolidation — wait for LTF break in " + dir_d + " direction" : "No delivery in progress — observe only"

// ── 1H LEG CONFIRMATION ──────────────────────────────────────────────────────
string leg_status = ltf_confirm ? "CONFIRMING" : in_pullback ? "PULLBACK LEG" : "NEUTRAL"
color  leg_col    = ltf_confirm ? color.lime : in_pullback ? color.yellow : color.gray

// ── 15M ENTRY TIMING ─────────────────────────────────────────────────────────
bool timing_ready   = dir_m == dir_4 and regime_m == "WITHIN"
bool timing_forming = dir_m == dir_4 and regime_m == "BEYOND"
string timing_status = timing_ready ? "READY" : timing_forming ? "FORMING" : "WAIT"
color  timing_col    = timing_ready ? color.lime : timing_forming ? color.yellow : color.red

// ── TRADING HORIZON RECOMMENDATIONS ─────────────────────────────────────────
string scalp_rec    = (journey_state == 1 or journey_state == 3) and timing_ready ? "TRADE" : (journey_state == 1 or journey_state == 3) and timing_forming ? "FORMING" : journey_state == 2 ? "WAIT — pullback" : journey_state == 4 ? "WAIT — consolidation" : "NO TRADE"

string intraday_rec = (journey_state == 1 or journey_state == 3) and ltf_confirm ? "TRADE" : journey_state == 4 and ltf_confirm ? "WATCH — discovery" : journey_state == 2 ? "WATCH — monitor " + str.tostring(dest_1, format.mintick) : journey_state == 5 ? "NO TRADE" : "WAIT"

string swing_rec    = (journey_state == 1 or journey_state == 3) and weekly_mod != "OPPOSING" ? "TRADE" : (journey_state == 1 or journey_state == 3) and weekly_mod == "OPPOSING" ? "REDUCED SIZE" : journey_state == 2 and htf_agree ? "WATCH — pullback entry soon" : journey_state == 4 ? "WATCH — next leg forming" : "NO TRADE"

color scalp_col    = scalp_rec    == "TRADE" ? color.lime : scalp_rec    == "FORMING" ? color.yellow : scalp_rec    == "NO TRADE" ? color.red : color.orange
color intraday_col = intraday_rec == "TRADE" ? color.lime : intraday_rec == "NO TRADE" ? color.red : intraday_rec == "WAIT" ? color.orange : color.yellow
color swing_col    = swing_rec    == "TRADE" ? color.lime : swing_rec    == "NO TRADE" ? color.red : color.yellow

// ── DESTINATION LINES + LABELS ────────────────────────────────────────────────
// One horizontal line per TF extending label_offset bars right.
// Smart vertical label offset: if any two destinations are within 0.3×ATR14,
// nudge the labels vertically by 0.4×ATR14 so text doesn't collide.

var line  ln_d = na
var line  ln_4 = na
var line  ln_1 = na
var line  ln_m = na
var label lb_d = na
var label lb_4 = na
var label lb_1 = na
var label lb_m = na

float atr14_cur = ta.atr(14)

if barstate.islast and show_lines
    line.delete(ln_d)
    line.delete(ln_4)
    line.delete(ln_1)
    line.delete(ln_m)
    label.delete(lb_d)
    label.delete(lb_4)
    label.delete(lb_1)
    label.delete(lb_m)

    int   x1    = bar_index
    int   x2    = bar_index + label_offset
    float atr_t = math.max(atr14_cur, syminfo.mintick)
    float bump  = atr_t * 0.4
    float thr   = atr_t * 0.3
    ls          = f_lstyle(line_style_inp)
    lsz         = f_sz(label_size_inp)

    // Label y-positions (lines stay at true price)
    float lyd = dest_d
    float ly4 = dest_4
    float ly1 = dest_1
    float lym = dest_m

    // Collision avoidance — check all 6 pairs
    if math.abs(lyd - ly4) < thr
        lyd := math.max(lyd, ly4) + bump
        ly4 := math.min(dest_d, dest_4) - bump
    if math.abs(lyd - ly1) < thr
        lyd := math.max(lyd, ly1) + bump
        ly1 := math.min(dest_d, dest_1) - bump
    if math.abs(lyd - lym) < thr
        lyd := math.max(lyd, lym) + bump
        lym := math.min(dest_d, dest_m) - bump
    if math.abs(ly4 - ly1) < thr
        ly4 := math.max(ly4, ly1) + bump
        ly1 := math.min(dest_4, dest_1) - bump
    if math.abs(ly4 - lym) < thr
        ly4 := math.max(ly4, lym) + bump
        lym := math.min(dest_4, dest_m) - bump
    if math.abs(ly1 - lym) < thr
        ly1 := math.max(ly1, lym) + bump
        lym := math.min(dest_1, dest_m) - bump

    ln_d := line.new(x1, dest_d, x2, dest_d, color=line_daily_col, width=line_width, style=ls, extend=extend.none)
    ln_4 := line.new(x1, dest_4, x2, dest_4, color=line_h4_col,    width=line_width, style=ls, extend=extend.none)
    ln_1 := line.new(x1, dest_1, x2, dest_1, color=line_h1_col,    width=line_width, style=ls, extend=extend.none)
    ln_m := line.new(x1, dest_m, x2, dest_m, color=line_m15_col,   width=line_width, style=ls, extend=extend.none)

    lb_d := label.new(x2, lyd, "D: "   + str.tostring(dest_d, format.mintick), color=color.new(color.black, 100), textcolor=line_daily_col, style=label.style_label_left, size=lsz)
    lb_4 := label.new(x2, ly4, "4H: "  + str.tostring(dest_4, format.mintick), color=color.new(color.black, 100), textcolor=line_h4_col,    style=label.style_label_left, size=lsz)
    lb_1 := label.new(x2, ly1, "1H: "  + str.tostring(dest_1, format.mintick), color=color.new(color.black, 100), textcolor=line_h1_col,    style=label.style_label_left, size=lsz)
    lb_m := label.new(x2, lym, "15m: " + str.tostring(dest_m, format.mintick), color=color.new(color.black, 100), textcolor=line_m15_col,   style=label.style_label_left, size=lsz)

// ── TIME-DISTANCE STATES ──────────────────────────────────────────────────────
// Uses dest_1/dest_4/dest_d already computed above. No new security calls.
// When show_td=false every state defaults to "STALLED" — never rendered.
td_state_1h = show_td ? f_td_state(dest_1, dest_1[td_lookback], close, close[td_lookback], atr14_cur, td_lookback, td_slope_thr) : "STALLED"
td_state_4h = show_td ? f_td_state(dest_4, dest_4[td_lookback], close, close[td_lookback], atr14_cur, td_lookback, td_slope_thr) : "STALLED"
td_state_d  = show_td ? f_td_state(dest_d, dest_d[td_lookback], close, close[td_lookback], atr14_cur, td_lookback, td_slope_thr) : "STALLED"

// Combined score: CONVERGING/APPROACHING = +1, DIVERGING/STALLED = -1  (range -3 to +3)
td_score_1h = td_state_1h == "CONVERGING" or td_state_1h == "APPROACHING" ? 1 : -1
td_score_4h = td_state_4h == "CONVERGING" or td_state_4h == "APPROACHING" ? 1 : -1
td_score_d  = td_state_d  == "CONVERGING" or td_state_d  == "APPROACHING" ? 1 : -1
td_combined_score = td_score_1h + td_score_4h + td_score_d

td_combined_label = td_combined_score >= 2 ? "STRONG POSITIVE" : td_combined_score == 1 ? "POSITIVE" : td_combined_score == -1 ? "NEGATIVE" : td_combined_score <= -2 ? "STRONG NEGATIVE" : "NEUTRAL"

td_combined_col = td_combined_score >= 2 ? color.lime : td_combined_score == 1 ? color.aqua : td_combined_score == -1 ? color.orange : td_combined_score <= -2 ? color.red : color.gray

// ── VWAP FIELD DOMINANCE ─────────────────────────────────────────────────────
grav_d  = show_td ? f_gravity(vwap_d, vwap_d[td_lookback], close, atr14_cur, td_lookback) : 0.0
grav_4  = show_td ? f_gravity(vwap_4, vwap_4[td_lookback], close, atr14_cur, td_lookback) : 0.0
grav_1  = show_td ? f_gravity(vwap_1, vwap_1[td_lookback], close, atr14_cur, td_lookback) : 0.0

dom_field = grav_d >= grav_4 and grav_d >= grav_1 ? "DAILY" : grav_4 >= grav_d and grav_4 >= grav_1 ? "4H" : "1H"
dom_col   = dom_field == "DAILY" ? color.yellow : dom_field == "4H" ? color.orange : color.aqua
dom_note  = dom_field == "DAILY" ? "Daily magnet dominant — trade toward daily dest" : dom_field == "4H" ? "4H controlling — oscillation within 4H structure" : "1H pulling — micro mean-reversion in progress"

// ── TIME-WEIGHTED DISPLACEMENT ACCUMULATION (TDPA) ────────────────────────────
// Accumulates each bar price stays beyond 1σ from VWAP; resets on VWAP cross.
var float tdpa_d = 0.0
var float tdpa_4 = 0.0
var float tdpa_1 = 0.0

if show_td
    dist_d_sigma = sigma_d > 0 ? math.abs(close - vwap_d) / sigma_d : 0.0
    cross_d = (close > vwap_d) != (close[1] > vwap_d[1])
    tdpa_d := cross_d ? 0.0 : tdpa_d + (dist_d_sigma > 1.0 ? dist_d_sigma : 0.0)

    dist_4_sigma = sigma_4 > 0 ? math.abs(close - vwap_4) / sigma_4 : 0.0
    cross_4 = (close > vwap_4) != (close[1] > vwap_4[1])
    tdpa_4 := cross_4 ? 0.0 : tdpa_4 + (dist_4_sigma > 1.0 ? dist_4_sigma : 0.0)

    dist_1_sigma = sigma_1 > 0 ? math.abs(close - vwap_1) / sigma_1 : 0.0
    cross_1 = (close > vwap_1) != (close[1] > vwap_1[1])
    tdpa_1 := cross_1 ? 0.0 : tdpa_1 + (dist_1_sigma > 1.0 ? dist_1_sigma : 0.0)

tdpa_combined = tdpa_d * 0.5 + tdpa_4 * 0.3 + tdpa_1 * 0.2
tdpa_level    = tdpa_combined < 5.0 ? "LOW" : tdpa_combined < 15.0 ? "MEDIUM" : tdpa_combined < 30.0 ? "HIGH" : "EXTREME"
tdpa_col      = tdpa_combined < 5.0 ? color.gray : tdpa_combined < 15.0 ? color.yellow : tdpa_combined < 30.0 ? color.orange : color.red
tdpa_note     = tdpa_level == "LOW" ? "Fresh displacement — trend continuation likely" : tdpa_level == "MEDIUM" ? "Building pressure — monitor for reversal signs" : tdpa_level == "HIGH" ? "High fatigue — mean reversion risk elevated" : "EXTREME — snapback risk very high, reduce size"

// ── PROP FIRM GATE CHECKS ─────────────────────────────────────────────────────
// Computed from inputs + Pine built-ins. journey_state and td_combined_score
// are already defined above — no new security calls needed.
prop_daily_limit = prop_acct_size * prop_daily_dd / 100
prop_max_limit   = prop_acct_size * prop_max_dd / 100
prop_risk_dollar = prop_acct_size * prop_risk_pct / 100
prop_lot_size    = math.round(prop_risk_dollar / (prop_acct_size * 0.01) * 0.01, 2)

prop_is_friday   = dayofweek == 6
prop_after_hours = hour >= 20
prop_wknd_gate   = prop_wknd_ok or not prop_is_friday
prop_ovn_gate    = prop_ovn_ok  or not prop_after_hours
prop_dd_gate     = prop_dd_used < prop_daily_limit
prop_pos_gate    = prop_pos_open < prop_max_pos
prop_tr_gate     = prop_tr_today < prop_max_tr
prop_audit_gate  = prop_audit_cur >= prop_min_audit
prop_js_gate     = prop_min_js == 1 ? journey_state == 1 : prop_min_js == 3 ? (journey_state == 1 or journey_state == 3) : (journey_state == 1 or journey_state == 2 or journey_state == 3)
prop_td_gate     = not show_td or td_combined_score >= prop_min_td
prop_news_gate   = prop_news_ok

prop_all_pass    = prop_dd_gate and prop_pos_gate and prop_tr_gate and prop_audit_gate and prop_js_gate and prop_td_gate and prop_wknd_gate and prop_ovn_gate and prop_news_gate

prop_fail_reason = not prop_dd_gate    ? "Daily DD " + str.tostring(math.round(prop_dd_used / prop_daily_limit * 100)) + "% used" : not prop_pos_gate  ? "Max positions reached (" + str.tostring(prop_pos_open) + "/" + str.tostring(prop_max_pos) + ")" : not prop_tr_gate   ? "Max trades today (" + str.tostring(prop_tr_today) + "/" + str.tostring(prop_max_tr) + ")" : not prop_audit_gate ? "Audit " + str.tostring(prop_audit_cur) + "/10 below min " + str.tostring(prop_min_audit) : not prop_js_gate   ? "Journey State " + str.tostring(journey_state) + " not allowed" : not prop_td_gate   ? "TD score " + str.tostring(td_combined_score) + " below min " + str.tostring(prop_min_td) : not prop_wknd_gate  ? "Friday — weekend hold disabled" : not prop_ovn_gate   ? "After hours — overnight hold disabled" : not prop_news_gate  ? "News trading restricted by firm" : "All gates pass"

prop_dir_word  = dir_4 == "BULL" ? "LONG" : "SHORT"
prop_signal    = prop_all_pass ? "TRADE " + prop_dir_word + " — $" + str.tostring(math.round(prop_risk_dollar), "#") + " risk / " + str.tostring(prop_lot_size, "#.##") + " lots" : "BLOCKED — " + prop_fail_reason
prop_signal_col = prop_all_pass ? color.lime : color.red

// ── TABLE (recreated every barstate.islast so row count is always correct) ───
table tbl = na

if barstate.islast
    tbl := table.new(position.bottom_right, 4, 32, border_width=1, border_color=color.new(color.gray, 60))
    sz  = f_sz(tbl_size_in)
    bg  = color.new(color.black, 70)
    hdr = color.new(color.gray, 50)

    // Header row 0
    table.cell(tbl, 0, 0, "H2 MTF v1.0",  text_color=color.white, bgcolor=hdr, text_size=sz)
    table.cell(tbl, 1, 0, "REGIME",        text_color=color.white, bgcolor=hdr, text_size=sz)
    table.cell(tbl, 2, 0, "DESTINATION",   text_color=color.white, bgcolor=hdr, text_size=sz)
    table.cell(tbl, 3, 0, "ROLE",          text_color=color.white, bgcolor=hdr, text_size=sz)

    // Weekly row 1 (optional)
    if show_weekly
        table.cell(tbl, 0, 1, "WEEKLY",    text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, 1, dir_w + " " + regime_w, text_color=weekly_col, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, 1, str.tostring(dest_w, format.mintick), text_color=color.aqua, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, 1, weekly_mod + " · " + weekly_size, text_color=weekly_col, bgcolor=bg, text_size=sz)

    int r = show_weekly ? 2 : 1

    // Daily
    table.cell(tbl, 0, r,   "DAILY",       text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r,   dir_d + " " + regime_d, text_color=dir_d == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r,   str.tostring(dest_d, format.mintick) + " · " + str.tostring(runway_d) + "R", text_color=color.aqua, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r,   "DESTINATION", text_color=color.gray, bgcolor=bg, text_size=sz)

    // 4H
    table.cell(tbl, 0, r+1, "4H",          text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+1, dir_4 + " " + regime_4, text_color=dir_4 == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+1, str.tostring(dest_4, format.mintick) + " · " + str.tostring(runway_4) + "R", text_color=color.aqua, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+1, "JOURNEY STATE", text_color=color.gray, bgcolor=bg, text_size=sz)

    // 1H
    table.cell(tbl, 0, r+2, "1H",          text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+2, dir_1 + " " + regime_1, text_color=dir_1 == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+2, str.tostring(dest_1, format.mintick) + " · " + str.tostring(runway_1) + "R", text_color=color.aqua, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+2, leg_status, text_color=leg_col, bgcolor=bg, text_size=sz)

    // 15M
    table.cell(tbl, 0, r+3, "15M",         text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+3, dir_m + " " + regime_m, text_color=dir_m == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+3, str.tostring(dest_m, format.mintick) + " · " + str.tostring(runway_m) + "R", text_color=color.aqua, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+3, timing_status, text_color=timing_col, bgcolor=bg, text_size=sz)

    // Journey separator
    table.cell(tbl, 0, r+4, "── JOURNEY ──", text_color=color.gray, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+4, "", bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+4, "", bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+4, "", bgcolor=bg, text_size=sz)

    // Journey state label
    state_advisory = journey_state == 1 ? "Price near target. Set entry alert. Prepare size." : journey_state == 2 ? "Do NOT enter. Wait for pullback to complete. Monitor 1H dest." : journey_state == 3 ? "Best entry window. Pullback done. Enter on 15M confirmation." : journey_state == 4 ? "Wait. Price overextended. Watch for LTF break back into range." : "Stand aside. No delivery in progress. No trade."
    table.cell(tbl, 0, r+5, journey_label,   text_color=journey_col, bgcolor=color.new(journey_col, 80), text_size=sz)
    table.cell(tbl, 1, r+5, "",              bgcolor=color.new(journey_col, 80), text_size=sz)
    table.cell(tbl, 2, r+5, state_advisory,  text_color=journey_col, bgcolor=color.new(journey_col, 85), text_size=sz, text_halign=text.align_left)
    table.cell(tbl, 3, r+5, "",              bgcolor=color.new(journey_col, 80), text_size=sz)

    // Journey action
    table.cell(tbl, 0, r+6, "ACTION",       text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+6, journey_action, text_color=journey_col, bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+6, "", bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+6, "", bgcolor=bg, text_size=sz)

    // Horizons separator
    table.cell(tbl, 0, r+7, "── HORIZONS ──", text_color=color.gray, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+7, "", bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+7, "", bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+7, "", bgcolor=bg, text_size=sz)

    // Scalp
    table.cell(tbl, 0, r+8, "SCALP (15m)",   text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+8, scalp_rec,        text_color=scalp_col,  bgcolor=color.new(scalp_col, 80), text_size=sz)
    table.cell(tbl, 2, r+8, timing_status,    text_color=timing_col, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+8, "Timing: 15m",   text_color=color.gray, bgcolor=bg, text_size=sz)

    // Intraday
    table.cell(tbl, 0, r+9, "INTRADAY (1H)", text_color=color.white,   bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+9, intraday_rec,     text_color=intraday_col, bgcolor=color.new(intraday_col, 80), text_size=sz)
    table.cell(tbl, 2, r+9, leg_status,       text_color=leg_col,      bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+9, "Confirm: 1H",   text_color=color.gray,   bgcolor=bg, text_size=sz)

    // Swing
    table.cell(tbl, 0, r+10, "SWING (4H+)",  text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+10, swing_rec,       text_color=swing_col,  bgcolor=color.new(swing_col, 80), text_size=sz)
    table.cell(tbl, 2, r+10, weekly_mod,      text_color=weekly_col, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+10, "Weekly: " + weekly_mod, text_color=weekly_col, bgcolor=bg, text_size=sz)

    // Panel 3 handoff row
    table.cell(tbl, 0, r+11, "→ PANEL 3",   text_color=color.gray,  bgcolor=bg, text_size=sz)
    table.cell(tbl, 1, r+11, journey_label,  text_color=journey_col, bgcolor=bg, text_size=sz)
    table.cell(tbl, 2, r+11, "S:" + scalp_rec + " I:" + intraday_rec, text_color=color.white, bgcolor=bg, text_size=sz)
    table.cell(tbl, 3, r+11, "W:" + swing_rec, text_color=swing_col, bgcolor=bg, text_size=sz)

    // ── TIME-DISTANCE SECTION (rows r+12 to r+16 — blank when show_td=false) ──
    if show_td
        // Separator row
        table.cell(tbl, 0, r+12, "── TIME-DISTANCE ──", text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+12, "STATE",               text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+12, "SIGNAL",              text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+12, "EDGE",                text_color=color.gray, bgcolor=bg, text_size=sz)

        // 1H time-distance
        td1c = f_td_col(td_state_1h)
        table.cell(tbl, 0, r+13, "1H T-D",    text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+13, td_state_1h, text_color=td1c, bgcolor=color.new(td1c, 80), text_size=sz)
        table.cell(tbl, 2, r+13, dir_1 == "BULL" ? "UP" : "DOWN", text_color=dir_1 == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+13, f_td_edge(td_state_1h), text_color=td1c, bgcolor=bg, text_size=sz)

        // 4H time-distance
        td4c = f_td_col(td_state_4h)
        table.cell(tbl, 0, r+14, "4H T-D",    text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+14, td_state_4h, text_color=td4c, bgcolor=color.new(td4c, 80), text_size=sz)
        table.cell(tbl, 2, r+14, dir_4 == "BULL" ? "UP" : "DOWN", text_color=dir_4 == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+14, f_td_edge(td_state_4h), text_color=td4c, bgcolor=bg, text_size=sz)

        // Daily time-distance
        tddc = f_td_col(td_state_d)
        table.cell(tbl, 0, r+15, "D T-D",    text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+15, td_state_d, text_color=tddc, bgcolor=color.new(tddc, 80), text_size=sz)
        table.cell(tbl, 2, r+15, dir_d == "BULL" ? "UP" : "DOWN", text_color=dir_d == "BULL" ? color.lime : color.red, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+15, f_td_edge(td_state_d), text_color=tddc, bgcolor=bg, text_size=sz)

        // Combined signal
        table.cell(tbl, 0, r+16, "COMBINED",        text_color=color.white,      bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+16, td_combined_label, text_color=td_combined_col,  bgcolor=color.new(td_combined_col, 75), text_size=sz)
        table.cell(tbl, 2, r+16, str.tostring(td_combined_score) + "/3 TFs", text_color=td_combined_col, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+16, "8-bar look",      text_color=color.gray,       bgcolor=bg, text_size=sz)

        // VWAP field dominance row
        table.cell(tbl, 0, r+17, "DOMINANCE",  text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+17, dom_field + " FIELD", text_color=dom_col, bgcolor=color.new(dom_col, 80), text_size=sz)
        table.cell(tbl, 2, r+17, dom_note,     text_color=dom_col, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tbl, 3, r+17, "D:" + str.tostring(grav_d, "#.#") + " 4H:" + str.tostring(grav_4, "#.#") + " 1H:" + str.tostring(grav_1, "#.#"), text_color=color.gray, bgcolor=bg, text_size=sz)

        // Time-weighted displacement pressure row
        table.cell(tbl, 0, r+18, "PRESSURE",   text_color=color.white,  bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+18, tdpa_level,   text_color=tdpa_col, bgcolor=color.new(tdpa_col, 80), text_size=sz)
        table.cell(tbl, 2, r+18, tdpa_note,    text_color=tdpa_col, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tbl, 3, r+18, "D:" + str.tostring(tdpa_d, "#.#") + " 4H:" + str.tostring(tdpa_4, "#.#"), text_color=color.gray, bgcolor=bg, text_size=sz)

        // Narrative split into SITUATION (r+19) and TRIGGER (r+20)
        narr_col  = td_combined_score >= 1 and journey_state <= 3 ? color.lime : td_combined_score <= -1 or journey_state == 5 ? color.red : color.yellow
        situation = f_situation(journey_state, td_combined_score, td_state_4h, dir_4, dest_4, runway_4, weekly_mod, dom_field, tdpa_level)
        trigger   = f_trigger(journey_state, dir_4)
        table.cell(tbl, 0, r+19, "SITUATION", text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+19, situation, text_color=narr_col, bgcolor=color.new(narr_col, 85), text_size=sz, text_halign=text.align_left)
        table.cell(tbl, 2, r+19, "", bgcolor=color.new(narr_col, 85), text_size=sz)
        table.cell(tbl, 3, r+19, "", bgcolor=color.new(narr_col, 85), text_size=sz)
        table.cell(tbl, 0, r+20, "TRIGGER", text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+20, trigger, text_color=narr_col, bgcolor=color.new(narr_col, 85), text_size=sz, text_halign=text.align_left)
        table.cell(tbl, 2, r+20, "", bgcolor=color.new(narr_col, 85), text_size=sz)
        table.cell(tbl, 3, r+20, "", bgcolor=color.new(narr_col, 85), text_size=sz)

    // ── PROP FIRM GATE SECTION (rows r+21 to r+27 — blank when show_prop=false) ─
    if show_prop
        // Separator
        table.cell(tbl, 0, r+21, "── PROP FIRM ──",      text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+21, "LIMIT",                 text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+21, "USED / STATE",          text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+21, "GATE",                  text_color=color.gray, bgcolor=bg, text_size=sz)

        // Daily drawdown
        dd_pct_used = prop_daily_limit > 0 ? prop_dd_used / prop_daily_limit * 100 : 0.0
        dd_col = prop_dd_gate ? (dd_pct_used > 80 ? color.yellow : color.lime) : color.red
        table.cell(tbl, 0, r+22, "Daily DD",              text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+22, "$" + str.tostring(math.round(prop_daily_limit), "#"), text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+22, "$" + str.tostring(math.round(prop_dd_used), "#") + " used", text_color=dd_col, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+22, prop_dd_gate ? "PASS" : "FAIL", text_color=dd_col, bgcolor=color.new(dd_col, 80), text_size=sz)

        // Positions + trades
        pos_tr_pass = prop_pos_gate and prop_tr_gate
        pos_tr_col  = pos_tr_pass ? color.lime : color.red
        table.cell(tbl, 0, r+23, "Pos / Trades",          text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+23, str.tostring(prop_max_pos) + " max / " + str.tostring(prop_max_tr) + " max", text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+23, str.tostring(prop_pos_open) + " open / " + str.tostring(prop_tr_today) + " today", text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+23, pos_tr_pass ? "PASS" : "FAIL", text_color=pos_tr_col, bgcolor=color.new(pos_tr_col, 80), text_size=sz)

        // H2 system gates
        h2_pass   = prop_audit_gate and prop_js_gate and prop_td_gate
        h2_col    = h2_pass ? color.lime : color.red
        table.cell(tbl, 0, r+24, "H2 Gates",              text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+24, "A>=" + str.tostring(prop_min_audit) + " JS<=" + str.tostring(prop_min_js) + " TD>=" + str.tostring(prop_min_td), text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+24, "A:" + str.tostring(prop_audit_cur) + " JS:" + str.tostring(journey_state) + " TD:" + str.tostring(td_combined_score), text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+24, h2_pass ? "PASS" : "FAIL", text_color=h2_col, bgcolor=color.new(h2_col, 80), text_size=sz)

        // Firm restrictions
        restr_pass = prop_wknd_gate and prop_ovn_gate and prop_news_gate
        restr_col  = restr_pass ? color.lime : color.red
        wknd_str   = prop_wknd_ok ? "Wknd OK" : (prop_is_friday ? "FRI-WARN" : "Wknd OK")
        ovn_str    = prop_ovn_ok  ? "Ovn OK"  : (prop_after_hours ? "AH-WARN" : "Ovn OK")
        news_str   = prop_news_ok ? "News OK" : "News OFF"
        table.cell(tbl, 0, r+25, "Firm Rules",            text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+25, "Wknd / Ovn / News",    text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+25, wknd_str + " " + ovn_str + " " + news_str, text_color=restr_col, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+25, restr_pass ? "PASS" : "FAIL", text_color=restr_col, bgcolor=color.new(restr_col, 80), text_size=sz)

        // Position sizing
        table.cell(tbl, 0, r+26, "Position Size",         text_color=color.white, bgcolor=bg, text_size=sz)
        table.cell(tbl, 1, r+26, str.tostring(prop_risk_pct, "#.#") + "% = $" + str.tostring(math.round(prop_risk_dollar), "#"), text_color=color.gray, bgcolor=bg, text_size=sz)
        table.cell(tbl, 2, r+26, str.tostring(prop_lot_size, "#.##") + " lots", text_color=color.aqua, bgcolor=bg, text_size=sz)
        table.cell(tbl, 3, r+26, "", bgcolor=bg, text_size=sz)

        // Final prop signal — full-width visual
        table.cell(tbl, 0, r+27, "PROP SIGNAL",           text_color=color.white, bgcolor=color.new(prop_signal_col, 70), text_size=sz)
        table.cell(tbl, 1, r+27, prop_signal,             text_color=prop_signal_col, bgcolor=color.new(prop_signal_col, 80), text_size=sz, text_halign=text.align_left)
        table.cell(tbl, 2, r+27, "",                      bgcolor=color.new(prop_signal_col, 80), text_size=sz)
        table.cell(tbl, 3, r+27, "",                      bgcolor=color.new(prop_signal_col, 80), text_size=sz)

// ── ALERTS (only fire when show_td is enabled) ────────────────────────────────
// Fires on confirmed bar close when 4H T-D state changes — for signal log.
td_state_changed = show_td and barstate.isconfirmed and td_state_4h != td_state_4h[1]

if td_state_changed
    alert('{"type":"td_state_change","symbol":"' + syminfo.ticker + '","tf":"4H","state":"' + td_state_4h + '","prev_state":"' + td_state_4h[1] + '","dest_4h":' + str.tostring(dest_4, "#.##") + ',"price":' + str.tostring(close, "#.##") + ',"journey_state":' + str.tostring(journey_state) + ',"combined_score":' + str.tostring(td_combined_score) + ',"timestamp":' + str.tostring(math.round(time / 1000)) + '}', alert.freq_once_per_bar_close)

// Manual alertconditions (set in TradingView Alerts dialog)
alertcondition(show_td and td_state_4h == "DIVERGING", title="H2 TD — 4H DIVERGING", message="Time-distance DIVERGING on 4H — destination running away from price")
alertcondition(show_td and (td_state_4h == "CONVERGING" or td_state_4h == "APPROACHING"), title="H2 TD — 4H POSITIVE", message="Time-distance POSITIVE on 4H — destination and price converging")

plot(na)
